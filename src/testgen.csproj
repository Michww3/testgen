<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>

		<PackAsTool>true</PackAsTool>
		<ToolCommandName>testgen</ToolCommandName>

		<PackageId>testgen</PackageId>
		<Authors>Michww3</Authors>
		<Description>CLI tool for generating hash-based unit tests for C# models</Description>
		<PackageTags>testing;codegen;dotnet-tool</PackageTags>

		<RepositoryUrl>https://github.com/Michww3/testgen</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<IncludePackageReadmeFile>true</IncludePackageReadmeFile>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<None Include="../README.md" Pack="true" PackagePath="" />
	</ItemGroup>

</Project>